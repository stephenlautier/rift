# MFE remote URLs used by the Module Federation host.
# In dev, these are irrelevant (the alias plugin resolves MFE imports from
# the workspace source directly), but they are needed for `vite preview`.
MFE_CHAMPIONS_URL=/static-assets/mfes/mfe-champions
MFE_TIER_LIST_URL=/static-assets/mfes/mfe-tier-list

# API base URL for the dev proxy target.
RIFT_API_URL=http://localhost:3100

# Filesystem paths to each MFE's built dist/ (relative to apps/shell/).
# Used by the Hono static asset handler in preview/production.
MFE_CHAMPIONS_DIST=../mfe-champions/dist
MFE_TIER_LIST_DIST=../mfe-tier-list/dist
