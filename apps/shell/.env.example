# =============================================================================
# shell — environment variables
# =============================================================================
# .env              ← committed base defaults (all modes)
# .env.development  ← committed dev-only overrides
# .env.local        ← gitignored personal overrides (any mode)
# .env.*.local      ← gitignored personal mode-specific overrides
# Production values must be set via the deployment platform, not committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth.js
# Generate with: npx auth secret  OR  openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=3000
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Module Federation remotes
# In production, set these to the deployed CDN/static URLs for each MFE.
# Leave unset to use the built-in fallback paths.
# -----------------------------------------------------------------------------
# MFE_CHAMPIONS_URL=https://cdn.example.com/mfes/mfe-champions
# MFE_TIER_LIST_URL=https://cdn.example.com/mfes/mfe-tier-list

# Filesystem paths to each MFE's built dist/ (relative to apps/shell/).
# Used by the Hono static asset handler in preview/production.
# MFE_CHAMPIONS_DIST=../mfe-champions/dist
# MFE_TIER_LIST_DIST=../mfe-tier-list/dist

# -----------------------------------------------------------------------------
# API
# Base URL for the Rift API server. Override in production to the deployed URL.
# -----------------------------------------------------------------------------
# RIFT_API_URL=http://localhost:3100
