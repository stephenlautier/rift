# =============================================================================
# api — environment variables
# =============================================================================
# .env              ← committed base defaults (loaded via --env-file=.env)
# .env.local        ← gitignored personal overrides
# .env.*.local      ← gitignored personal mode-specific overrides
# Production values must be set via the deployment platform, not committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=3100

# -----------------------------------------------------------------------------
# CORS
# Allowed origin for the shell app. Set to the deployed shell URL in production.
# -----------------------------------------------------------------------------
# SHELL_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# Path to the SQLite database file (relative to apps/api/).
# -----------------------------------------------------------------------------
# DATABASE_URL=./data/rift.db
