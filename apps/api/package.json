{
  "name": "@rift/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/app.mjs",
  "types": "./dist/app.d.mts",
  "exports": {
    ".": {
      "types": "./dist/app.d.mts",
      "import": "./dist/app.mjs"
    }
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "start": "node --env-file=.env --import tsx/esm src/index.ts",
    "serve": "node --env-file=.env --enable-source-maps dist/index.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/valibot-validator": "catalog:",
    "@rift/champion": "workspace:*",
    "@rift/player": "workspace:*",
    "better-sqlite3": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "oxlint": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
