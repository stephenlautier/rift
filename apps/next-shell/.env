# Shared auth secret — must be identical across all zones.
AUTH_SECRET=UCM2IBSR58spnUVEBmLMYtfTzs8H9MVs1Aj8eAgB7G4=

# Shell owns the NextAuth handlers; this is the public URL used as callback base.
AUTH_URL=http://localhost:3000

# Cookie domain for cross-zone JWT sharing. Leave blank for localhost dev.
COOKIE_DOMAIN=

# Zone URLs used by shell rewrites.
NEXT_CHAMPIONS_URL=http://localhost:3001
NEXT_TIER_LIST_URL=http://localhost:3002
NEXT_PLAYER_URL=http://localhost:3003

# Hono API URL for the /api proxy rewrite.
API_URL=http://localhost:3100

# Browser-visible API URL. Leave blank to use same-origin proxy through shell.
NEXT_PUBLIC_API_URL=

# Shell origin (used by non-shell zones for serverActions.allowedOrigins).
SHELL_ORIGIN=http://localhost:3000

# Port for this zone.
PORT=3000
