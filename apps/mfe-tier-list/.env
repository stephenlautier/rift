# Vite dev server origin — used as the Module Federation runtime `origin`
# so asset chunk URLs resolve correctly during `vite preview`.
MFE_TIER_LIST_URL=http://localhost:3012

# Public path for built assets (chunk URLs in the MF manifest).
MFE_TIER_LIST_PUBLIC_PATH=/static-assets/mfes/mfe-tier-list/

# Base URL of the Rift API server (server-side data fetching).
RIFT_API_URL=http://localhost:3100
