{
  "name": "next-champions",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/next-champions",
  "tags": ["type:app", "scope:champions"],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "options": {
        "root": "apps/next-champions",
        "outputPath": "dist/apps/next-champions"
      },
      "dependsOn": ["^build"]
    },
    "dev": {
      "executor": "@nx/next:server",
      "options": {
        "buildTarget": "next-champions:build",
        "dev": true,
        "port": 3001
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxlint --type-aware app",
        "cwd": "apps/next-champions"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt app",
        "cwd": "apps/next-champions"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt --check app",
        "cwd": "apps/next-champions"
      }
    }
  }
}
