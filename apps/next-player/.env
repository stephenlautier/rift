# Shared auth secret — must match next-shell exactly.
AUTH_SECRET=UCM2IBSR58spnUVEBmLMYtfTzs8H9MVs1Aj8eAgB7G4=

# Shell's public URL — NextAuth uses this to verify the JWT cookie and
# proxy.ts redirects unauthenticated requests to AUTH_URL/login.
AUTH_URL=http://localhost:3000

# Shell origin for serverActions.allowedOrigins and cross-zone sign-out.
SHELL_ORIGIN=http://localhost:3000

# Hono API URL for server-side data fetching.
API_URL=http://localhost:3100

# Port for this zone.
PORT=3003
