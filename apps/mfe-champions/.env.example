# =============================================================================
# mfe-champions — environment variables
# =============================================================================
# .env              ← committed base defaults (all modes)
# .env.development  ← committed dev-only overrides
# .env.local        ← gitignored personal overrides (any mode)
# .env.*.local      ← gitignored personal mode-specific overrides
# Production values must be set via the deployment platform, not committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# PORT=3001
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Module Federation
# Public path for built assets (chunk URLs in the MF manifest).
# In production, set to the CDN URL prefix.
# -----------------------------------------------------------------------------
# MFE_CHAMPIONS_PUBLIC_PATH=/static-assets/mfes/mfe-champions/

# URL of this MFE's dev/preview server (used as the MF runtime origin).
# MFE_CHAMPIONS_URL=http://localhost:3011

# -----------------------------------------------------------------------------
# API
# Base URL of the Rift API server (server-side data fetching).
# -----------------------------------------------------------------------------
# RIFT_API_URL=http://localhost:3100
