# ── Shared Auth (MUST be identical across all zones) ────────────────────────
AUTH_SECRET=changeme-use-openssl-rand-base64-32

# ── Shell (zone 0 — owns auth) ───────────────────────────────────────────────
# Public URL of the shell zone — used as NextAuth callback base and by non-shell
# zones for cross-zone sign-in/sign-out redirects.
AUTH_URL=http://localhost:3000

# Cookie domain for cross-zone JWT sharing.
# In development leave blank (defaults to per-hostname, sufficient for localhost).
# In production set to your root domain: .example.com
COOKIE_DOMAIN=

# ── Zone URLs (used by shell rewrites + non-shell auth) ──────────────────────
NEXT_CHAMPIONS_URL=http://localhost:3001
NEXT_TIER_LIST_URL=http://localhost:3002
NEXT_PLAYER_URL=http://localhost:3003

# ── API ───────────────────────────────────────────────────────────────────────
API_URL=http://localhost:3100
# Browser-visible API URL. Leave blank to use the same-origin proxy through shell.
NEXT_PUBLIC_API_URL=

# ── Shell-origin (used by non-shell zones for serverActions.allowedOrigins) ──
SHELL_ORIGIN=http://localhost:3000

# ── Database (api zone only) ──────────────────────────────────────────────────
DATABASE_URL=./data/rift.db

# ── Per-zone port (override in each zone's .env.local) ───────────────────────
# next-shell   → PORT=3000
# next-champions → PORT=3001
# next-tier-list → PORT=3002
# next-player    → PORT=3003
# api            → PORT=3100
PORT=3000
