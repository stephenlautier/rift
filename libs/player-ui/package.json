{
  "name": "@rift/player-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Player profile Stencil web components (relocated from apps/mfe-player). SSR-ready via dist-hydrate-script.",
  "files": [
    "dist/",
    "loader/",
    "hydrate/"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./react": {
      "types": "./src/react/components.ts",
      "node": "./src/react/components.server.ts",
      "import": "./src/react/components.ts"
    },
    "./react/ssr": {
      "types": "./src/react/components.server.ts",
      "import": "./src/react/components.server.ts"
    },
    "./loader": {
      "import": "./loader/index.js"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "import": "./hydrate/index.mjs",
      "require": "./hydrate/index.js",
      "default": "./hydrate/index.js"
    }
  },
  "scripts": {
    "build": "stencil build",
    "devx": "stencil build --dev --watch --serve",
    "generate": "stencil generate",
    "lint": "oxlint src/"
  },
  "dependencies": {
    "@rift/champion": "workspace:*",
    "@rift/data-access": "workspace:*",
    "@rift/player": "workspace:*",
    "@stencil/core": "catalog:",
    "@stencil/react-output-target": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "collection": "dist/collection/collection-manifest.json"
}
