{
  "name": "player-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/player-ui/src",
  "tags": ["type:lib", "scope:player-ui"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm build",
        "cwd": "libs/player-ui"
      },
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/hydrate",
        "{projectRoot}/loader",
        "{projectRoot}/src/react"
      ],
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxlint src/",
        "cwd": "libs/player-ui"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt src/",
        "cwd": "libs/player-ui"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm oxfmt --check src/",
        "cwd": "libs/player-ui"
      }
    }
  }
}
