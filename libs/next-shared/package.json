{
  "name": "@rift/next-shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared Next.js infrastructure: auth config, layout components, proxy factory",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth/config.ts",
      "import": "./src/auth/config.ts"
    },
    "./proxy": {
      "types": "./src/proxy/createAuthProxy.ts",
      "import": "./src/proxy/createAuthProxy.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "import": "./src/theme/index.ts"
    }
  },
  "dependencies": {
    "clsx": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "next": ">=16.0.0",
    "next-auth": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "next": "catalog:",
    "next-auth": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  }
}
