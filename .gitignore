# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
dist
tmp
/out-tsc

# Module Federation generated artifacts (per-MFE local cache)
**/.mf
**/.federation
**/.__mf__temp

# Stray TypeScript declaration outputs in source folders.
# These should never be committed — `.d.ts` files belong in `dist/` only.
# (Real hand-authored ambient declarations should live in `*.d.ts` files
# under a clearly-named folder e.g. `types/` or `global.d.ts` at app root.)
libs/*/src/**/*.d.ts
libs/*/src/**/*.d.ts.map
libs/*/src/**/*.js.map

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log

testem.log
/typings

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# System Files
.DS_Store
Thumbs.db

# nx
.nx/cache
.nx/workspace-data

.angular

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

