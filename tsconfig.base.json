{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "lib": ["ES2023", "dom"],
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@rift/auth": ["./libs/auth/src/index.ts"],
      "@rift/champion": ["./libs/champion/src/index.ts"],
      "@rift/next-shared": ["./libs/next-shared/src/index.ts"],
      "@rift/player": ["./libs/player/src/index.ts"],
      "@rift/player-ui": ["./libs/player-ui/src/index.ts"],
      "@rift/ui": ["./libs/ui/src/index.ts"],
      "@rift/ui/loader": ["./libs/ui/loader/index.d.ts"],
      "@rift/ui/components/*": ["./libs/ui/dist/components/*.d.ts"],
      "@rift/ui/dist/components": ["./libs/ui/dist/components/index.d.ts"],
      "@rift/ui/dist/components/*.js": ["./libs/ui/dist/components/*"],
      "@rift/ui/dist/components/*": ["./libs/ui/dist/components/*"],
      "@rift/data-access": ["./libs/data-access/src/index.ts"],
      "@rift/ts-shared": ["./labs/tanstack-mfe/libs/ts-shared/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".vike", "coverage"]
}
