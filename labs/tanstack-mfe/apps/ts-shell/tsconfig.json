{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "dom", "dom.iterable"],
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./app/*"]
    }
  },
  "include": ["app", "vite.config.ts"]
}
